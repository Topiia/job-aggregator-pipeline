<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Triggers the Topia Job Aggregator daily data extraction pipeline at 11:50 AM.</Description>
    <URI>\TopiaJobAggregator</URI>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-04-11T11:50:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT1H</ExecutionTimeLimit>
    <Enabled>true</Enabled>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>C:\Users\navi\projects\job_aggregator\venv\Scripts\python.exe</Command>
      <Arguments>C:\Users\navi\projects\job_aggregator\scripts\run_scraper.py</Arguments>
      <WorkingDirectory>C:\Users\navi\projects\job_aggregator</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
